From d52781c203139fdb450a6dc9b382d0b89bb5e50a Mon Sep 17 00:00:00 2001
From: SinaAb7 <sinaabdollahip@gmail.com>
Date: Sat, 24 Jan 2026 11:35:21 +0000
Subject: [PATCH] customizing scripts for automation

---
 buildfs.sh                         |  9 +++++++++
 disk_create.sh                     | 20 ++++++++++++++++++++
 opencca-image-rockchip-rk3588.yaml |  5 +++--
 opencca-ospack-debian.yaml         |  2 +-
 4 files changed, 33 insertions(+), 3 deletions(-)
 create mode 100755 buildfs.sh
 create mode 100755 disk_create.sh

diff --git a/buildfs.sh b/buildfs.sh
new file mode 100755
index 0000000..50c5942
--- /dev/null
+++ b/buildfs.sh
@@ -0,0 +1,9 @@
+#!/bin/bash
+
+DIR=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
+set -x
+cd $DIR
+mkdir out
+sudo debos --artifactdir=out -t architecture:arm64 ospack-debian.yaml
+sudo debos --artifactdir=out -t architecture:arm64 -t platform:rock5b-rk3588 opencca-image-rockchip-rk3588.yaml
+
diff --git a/disk_create.sh b/disk_create.sh
new file mode 100755
index 0000000..bf6da43
--- /dev/null
+++ b/disk_create.sh
@@ -0,0 +1,20 @@
+#!/bin/bash
+
+DIR=$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
+set -x
+
+echo "enter the right disk an input argument e.g., ./disk_create.sh sdc"
+
+if [ -z "$1" ]; then
+  echo "No disk specified. Exiting."
+  exit 1
+fi
+
+sudo bmaptool copy $DIR/out/opencca-image-rockchip-rock5b-rk3588.img.gz /dev/$1
+
+mkdir -p /mntc
+sudo mount /dev/$1"3" /mntc
+sudo cp $DIR/../snapshot/Image /mntc/boot/.
+sudo cp /mntc/boot/extlinux/extlinux.conf /mntc/boot/extlinux/extlinux.conf.bak
+sudo sed -i -E 's/^([[:space:]]*linux[[:space:]]+)\/boot[^[:space:]]*/\1\/boot\/Image/' /mntc/boot/extlinux/extlinux.conf
+sudo umount /mntc
diff --git a/opencca-image-rockchip-rk3588.yaml b/opencca-image-rockchip-rk3588.yaml
index ec25f57..25f1b7f 100644
--- a/opencca-image-rockchip-rk3588.yaml
+++ b/opencca-image-rockchip-rk3588.yaml
@@ -1,9 +1,9 @@
 {{ $architecture := or .architecture "arm64" }}
 {{ $suite := or .suite "trixie" }}
 {{ $ospack := or .ospack (printf "ospack-debian-%s-%s" $architecture $suite) }}
-{{ $imagesize := or .imagesize "4GB" }}
+{{ $imagesize := or .imagesize "8GB" }}
 {{ $platform := or .platform "unknown" }}
-{{ $cmdline := or .cmdline "rootwait maxcpus=2" }}
+{{ $cmdline := or .cmdline "console=ttyS2,1500000 earlycon rootwait maxcpus=2"}}
 {{ $image := or .image (printf "opencca-image-rockchip-%s" $platform) }}
 
 architecture: {{ $architecture }}
@@ -138,3 +138,4 @@ actions:
     description: Compress {{ $image }}.img
     postprocess: true
     command: pigz -f $ARTIFACTDIR/{{ $image }}.img
+
diff --git a/opencca-ospack-debian.yaml b/opencca-ospack-debian.yaml
index 9cdbbdb..46b542b 100644
--- a/opencca-ospack-debian.yaml
+++ b/opencca-ospack-debian.yaml
@@ -69,7 +69,7 @@ actions:
     packages:
       - sudo
       - adduser
-
+ 
   - action: run
     description: Setup user
     chroot: true
-- 

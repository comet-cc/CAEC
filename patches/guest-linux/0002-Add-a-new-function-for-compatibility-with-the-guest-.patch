Subject: [PATCH 2/2] Add a new function for compatibility with the guest
 drivers

---
 arch/arm64/include/asm/rsi_cmds.h | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/arch/arm64/include/asm/rsi_cmds.h b/arch/arm64/include/asm/rsi_cmds.h
index e6a211001bd3..e96c9a52f53b 100644
--- a/arch/arm64/include/asm/rsi_cmds.h
+++ b/arch/arm64/include/asm/rsi_cmds.h
@@ -20,6 +20,16 @@ enum ripas {
 	RSI_RIPAS_DEV = 3,
 };
 
+static inline void invoke_rsi_fn_smc_with_res(unsigned long function_id,
+                                              unsigned long arg0,
+                                              unsigned long arg1,
+                                              unsigned long arg2,
+                                              unsigned long arg3,
+                                              struct arm_smccc_res *res)
+{
+        arm_smccc_smc(function_id, arg0, arg1, arg2, arg3, 0, 0, 0, res);
+}
+
 static inline unsigned long rsi_request_version(unsigned long req,
 						unsigned long *out_lower,
 						unsigned long *out_higher)

+static int kvm_realm_enable_cap_prealloc(struct kvm *kvm,
+					 struct kvm_enable_cap *cap)
+{
+	struct kvm_rme_prealloc_rtt req;
+
+	if (!cap->args[1])
+		return -EINVAL;
+
+	if (copy_from_user(&req, (void __user *)(uintptr_t)cap->args[1], sizeof(req)))
+		return -EFAULT;
+
+	if (req.flags)
+		return -EINVAL;
+
+	pr_info("[RME-RTT] ENABLE_CAP PREALLOC: ipa=%#llx size=%#llx level=%u\n",
+		req.ipa_start, req.size, req.target_level);
+
+	return kvm_realm_prealloc_rtt_range(kvm, req.ipa_start, req.size, req.target_level);
+}

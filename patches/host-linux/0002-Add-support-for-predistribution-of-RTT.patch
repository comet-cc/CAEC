+/* -------- Explicit RTT preallocation for an IPA range (down to target_level) -------- */
+
+static int prebuild_rtts(struct realm *realm, u64 start, u64 end, int target_level)
+{
+	int root = get_start_level(realm);
+	int lvl;
+
+	if (target_level < root || target_level > 3)
+		return -EINVAL;
+
+	for (lvl = root + 1; lvl <= target_level; lvl++) {
+		u64 step = rme_rtt_level_mapsize(lvl - 1);   /* parent size! */
+		u64 aligned_start = ALIGN_DOWN(start, step);
+		u64 aligned_end   = ALIGN(end, step);
+
+		for (u64 ipa = aligned_start; ipa < aligned_end; ipa += step) {
+			phys_addr_t rtt = alloc_delegated_page(realm, NULL, GFP_KERNEL);
+			int rc;
+
+			if (!rtt || rtt == PHYS_ADDR_MAX)
+				return -ENOMEM;
+
+			rc = realm_rtt_create(realm, ipa, lvl, rtt);
+			if (rc) {
+				/* If the table at this level already exists, that's fine. */
+				if (RMI_RETURN_STATUS(rc) == RMI_ERROR_RTT &&
+				    RMI_RETURN_INDEX(rc) == lvl) {
+					free_delegated_page(realm, rtt);
+					continue;
+				}
+				free_delegated_page(realm, rtt);
+				return -EFAULT;
+			}
+		}
+	}
+	return 0;
+}
+
+int kvm_realm_prealloc_rtt_range(struct kvm *kvm, u64 ipa, u64 size, u32 target_level)
+{
+	struct realm *realm = &kvm->arch.realm;
+	u64 start = ipa, end = ipa + size;
+
+	if (!size || end <= start)
+		return -EINVAL;
+
+	pr_info("[RME-RTT] prealloc request: ipa=%#llx size=%#llx level=%u\n",
+		ipa, size, target_level);
+
+	return prebuild_rtts(realm, start, end, (int)target_level);
+}
+

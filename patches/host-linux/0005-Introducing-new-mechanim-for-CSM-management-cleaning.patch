+int kvm_realm_map_private_page(struct kvm *kvm, gpa_t ipa,
+                               struct kvm_mmu_memory_cache *memcache)
+{
+	struct realm *realm = &kvm->arch.realm;
+	gfn_t gfn = ipa >> PAGE_SHIFT;
+	struct kvm_memory_slot *memslot;
+	kvm_pfn_t pfn;
+	int ret;
+
+	/* Must be mapped via the private alias for a Realm */
+	if (!realm_is_addr_protected(realm, ipa))
+		return -EINVAL;
+
+	/* Find the memslot and ensure it can be private */
+	memslot = gfn_to_memslot(kvm, gfn);
+	if (!memslot || !kvm_slot_can_be_private(memslot))
+		return -EINVAL;
+
+	/* Top up the mapping memcache (uses mmu pointer, not struct-by-value!) */
+	ret = kvm_mmu_topup_memory_cache(memcache,
+					 kvm_mmu_cache_min_pages(&kvm->arch.mmu));
+	if (ret)
+		return ret;
+
+	/* Get the PFN from the Realm's private file (guest_memfd) */
+	ret = kvm_gmem_get_pfn(kvm, memslot, gfn, &pfn, NULL);
+	if (ret)
+		return ret;
+
+	/* Delegate/map one 4K granule to the Realm */
+	ret = realm_map_protected(realm, ipa, pfn_to_page(pfn),
+				  PAGE_SIZE, memcache);
+	if (ret)
+		put_page(pfn_to_page(pfn)); /* ownership didn't move on failure */
+
+	return ret;
+}

+
+#define L3_PAGE_SIZE    PAGE_SIZE
+#define L2_BLOCK_SIZE   SZ_2M
+
+
+/* Remove (destroy+undelegate) everything in [start, end), page by page. */
+int kvm_realm_remove_private_granules_vcpu(struct kvm_vcpu *vcpu,
+                                           unsigned long start,
+                                           unsigned long end)
+{
+    struct kvm *kvm = vcpu->kvm;
+
+    if (end <= start)
+        return -EINVAL;
+
+    /* Make sure block-split can allocate without sleeping. */
+    kvm_realm_ensure_spare_page(kvm);
+
+    realm_unmap_range_private(kvm, start, end);
+
+    return 0;
+}
+
+
+/* Ensure an L3 table exists for each 2MiB region covering [start, end). */
+static int realm_ensure_l3_tables_vcpu(struct kvm_vcpu *vcpu,
+                                       unsigned long start,
+                                       unsigned long end)
+{
+    struct kvm *kvm = vcpu->kvm;
+    struct realm *realm = &kvm->arch.realm;
+    struct kvm_mmu_memory_cache *mc = &vcpu->arch.mmu_page_cache;
+    phys_addr_t rd_phys = virt_to_phys(realm->rd);
+    unsigned long base = ALIGN_DOWN(start, L2_BLOCK_SIZE);
+    unsigned long top  = ALIGN(end,   L2_BLOCK_SIZE);
+    unsigned long ipa;
+
+    for (ipa = base; ipa < top; ipa += L2_BLOCK_SIZE) {
+        struct rtt_entry rtt;
+        int rc = rmi_rtt_read_entry(rd_phys, ipa, /*level=*/3, &rtt);
+
+        /*
+         * If the walk reaches L3 (walk_level == 3), an L3 table is present.
+         * Otherwise (e.g., walk_level == 2 or unmapped), we need to install one.
+         */
+        if (!rc && rtt.walk_level == RME_RTT_MAX_LEVEL){
+			pr_info("realm_ensure_l3_tables_vcpu: L3 already present at ipa=%lx. Skip.\n", ipa);
+            continue;
+		}
+
+
+        {
+            phys_addr_t new_rtt = alloc_delegated_page(realm, NULL, GFP_KERNEL);
+            if (!new_rtt || new_rtt == PHYS_ADDR_MAX) {
+              pr_info("realm_ensure_l3_tables_vcpu: alloc_delegated_page failed\n");
+                return -ENOMEM;
+            }
+
+            rc = realm_rtt_create(realm, ipa, 3, new_rtt);
+            if (rc) {
+                u32 st = RMI_RETURN_STATUS(rc);
+                u32 ix = RMI_RETURN_INDEX(rc);
+
+                /* Benign: already present (parent already a table). */
+                if (st == RMI_ERROR_RTT && (ix == 3 || ix == 2)) {
+                    free_delegated_page(realm, new_rtt);
+                    continue;
+                }
+                /* Real failure. */
+                free_delegated_page(realm, new_rtt);
+              
+                return -EFAULT;
+            }
+            /* Success: RMM consumed new_rtt; do not free it. */
+        }
+    }
+
+    return 0;
+}
+
+int kvm_realm_scrub_and_ensure_l3_vcpu(struct kvm_vcpu *vcpu,
+                                       unsigned long start,
+                                       unsigned long end)
+{
+    int ret;
+
+    if (end <= start)
+        return -EINVAL;
+
+    ret = kvm_realm_remove_private_granules_vcpu(vcpu, start, end);
+    if (ret) {
+        pr_err("[RME] remove failed [%#lx, %#lx): %d\n", start, end, ret);
+        return ret;
+    }
+
+
+    ret = realm_ensure_l3_tables_vcpu(vcpu, start, end);
+    if (ret)
+        return ret;
+	pr_info("finished scrub+ensure_l3 [%lx, %lx)\n", start, end);
+
+    return 0;
+}

+static int rec_exit_csm_remove_granules(struct kvm_vcpu *vcpu)
+{
+    struct kvm *kvm = vcpu->kvm;
+	struct realm_rec *rec = &vcpu->arch.rec;
+
+    unsigned long base = ALIGN_DOWN((phys_addr_t)rec->run->exit.ripas_base, PAGE_SIZE);
+	unsigned long top  = ALIGN((phys_addr_t)rec->run->exit.ripas_top, PAGE_SIZE);
+    int ret;
+
+    pr_info("[RME] CSM_REMOVE_GRANULES: [%#lx, %#lx)\n", base, top);
+    if (top <= base) return -EINVAL;
+
+    write_lock(&kvm->mmu_lock);
+
+    ret = kvm_realm_scrub_and_ensure_l3_vcpu(vcpu, base, top);
+    //kvm_flush_remote_tlbs(kvm);
+    write_unlock(&kvm->mmu_lock);
+
+    if (ret)
+        return -EIO;
+
+    return 1; // resume guest
+}
+

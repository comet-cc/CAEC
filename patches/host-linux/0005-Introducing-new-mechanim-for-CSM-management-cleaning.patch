+
 static int rec_exit_host_call(struct kvm_vcpu *vcpu)
 {
 	int ret, i;
@@ -135,6 +163,54 @@ static int rec_exit_host_call(struct kvm_vcpu *vcpu)
 	return ret;
 }
 
+static int rec_exit_csm_add_granules(struct kvm_vcpu *vcpu)
+{
+	struct kvm *kvm = vcpu->kvm;
+	struct realm *realm = &kvm->arch.realm;
+	struct realm_rec *rec = &vcpu->arch.rec;
+
+	unsigned long base = ALIGN_DOWN((phys_addr_t)rec->run->exit.ripas_base, PAGE_SIZE);
+	unsigned long top  = ALIGN((phys_addr_t)rec->run->exit.ripas_top, PAGE_SIZE);
+	int ret;
+
+	/* Better formatting for phys addr: */
+	pr_info("[RME] CSM_ADD_GRANULES: [%#lx, %#lx)\n", base, top);
+
+	if (top <= base)
+		return -EINVAL;
+
+	if (!realm_is_addr_protected(realm, base) ||
+	    !realm_is_addr_protected(realm, top - 1)) {
+		pr_err("[RME] CSM_ADD not fully private: [%pa, %pa)\n", &base, &top);
+		return -EINVAL;
+	}
+
+	/* Ensure we can create RTTs under lock if needed */
+	ret = kvm_mmu_topup_memory_cache(&vcpu->arch.mmu_page_cache,
+					 kvm_mmu_cache_min_pages(vcpu->arch.hw_mmu));
+	if (ret)
+		return ret;
+
+	write_lock(&kvm->mmu_lock);
+
+	/* Eager population using the vCPU+memslot aware helper */
+	ret = kvm_realm_add_private_granules_vcpu(vcpu, base, top);
+
+	write_unlock(&kvm->mmu_lock);
+
+	if (ret) {
+		pr_err("[RME] CSM_ADD_GRANULES failed [%pa, %pa): %d\n", &base, &top, ret);
+		return ret;
+	}
+
+	return 1; /* resume guest */
+}

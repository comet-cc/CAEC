+void kvm_realm_ensure_spare_page(struct kvm *kvm)
+{
+	/*
+	 * Wrapper around the internal ensure_spare_page() which operates
+	 * on struct realm.
+	 */
+	struct realm *realm = &kvm->arch.realm;
+
+	ensure_spare_page(realm);
+}
+
+
+static inline int rtt_leaf_matches(struct realm *realm,
+                                   phys_addr_t rd_phys,
+                                   phys_addr_t ipa,
+                                   phys_addr_t expect_phys)
+{
+    struct rtt_entry rtt;
+    int ret;
+
+    ret = rmi_rtt_read_entry(rd_phys, ipa, RME_RTT_MAX_LEVEL, &rtt);
+    if (ret)                
+        return ret;        
+
+   
+    if (rtt.walk_level != RME_RTT_MAX_LEVEL)
+        return 0;          
+
+    if (rtt.state != RMI_ASSIGNED)
+        return 0;          
+
+    if (rtt_get_phys(realm, &rtt) == expect_phys)
+        return 1;           /* same IPA→PA already installed */
+
+    return -EEXIST;
+}
+
+int kvm_realm_add_private_granules_vcpu(struct kvm_vcpu *vcpu,
+                                        unsigned long start,
+                                        unsigned long end)
+{
+    struct kvm *kvm = vcpu->kvm;
+    struct realm *realm = &kvm->arch.realm;
+    struct kvm_mmu_memory_cache *memcache = &vcpu->arch.mmu_page_cache;
+    phys_addr_t rd_phys = virt_to_phys(realm->rd);
+    phys_addr_t s = ALIGN_DOWN((phys_addr_t)start, PAGE_SIZE);
+    phys_addr_t e = ALIGN((phys_addr_t)end,   PAGE_SIZE);
+    phys_addr_t ipa;
+    int ret = 0;
+    int idx;
+
+    if (e <= s)
+        return -EINVAL;
+
+    pr_info("[RME][add_granules] request: [%pa, %pa) (%llu pages)\n",
+            &s, &e, (unsigned long long)((e - s) >> PAGE_SHIFT));
+
+    /* Memslot lookups must be under SRCU */
+    idx = srcu_read_lock(&kvm->srcu);
+
+    for (ipa = s; ipa < e; ipa += PAGE_SIZE) {
+        gfn_t gfn = ipa >> PAGE_SHIFT;
+        struct kvm_memory_slot *memslot;
+        kvm_pfn_t pfn;
+        struct page *page;
+        phys_addr_t expect_phys;
+        int match;
+
+
+		/* Top up the VCPU’s memory cache as needed. */
+    	ret = kvm_mmu_topup_memory_cache(&vcpu->arch.mmu_page_cache,
+				   kvm_mmu_cache_min_pages(vcpu->arch.hw_mmu));
+    	if (ret) {
+       	 	pr_err("topup failed: %d\n", ret);
+        	break;
+    	}
+
+        /* Pick/validate the memslot covering this GFN */
+        memslot = gfn_to_memslot(kvm, gfn);
+        if (!memslot ||
+            gfn < memslot->base_gfn ||
+            gfn >= memslot->base_gfn + memslot->npages ||
+            !kvm_slot_can_be_private(memslot)) {
+            pr_err("[RME][add_granules] bad memslot/can't be private: gfn=0x%llx\n",
+                   (unsigned long long)gfn);
+            ret = -EINVAL;
+            break;
+        }
+
+        /* Get (or prepare) the host PFN for this GFN (shared-side handle). */
+        ret = kvm_gmem_get_pfn(kvm, memslot, gfn, &pfn, NULL);
+        if (ret) {
+            pr_err("[RME][add_granules] kvm_gmem_get_pfn failed: gfn=0x%llx ret=%d\n",
+                   (unsigned long long)gfn, ret);
+            break;
+        }
+
+        page = pfn_to_page(pfn);
+        expect_phys = page_to_phys(page);
+
+        match = rtt_leaf_matches(realm, rd_phys, ipa, expect_phys);
+        if (match < 0) {
+            /* Conflict or read error — stop. */
+            kvm_release_pfn_clean(pfn);
+            ret = match;     /* typically -EEXIST or other <0 */
+            break;
+        }
+
+        if (match == 0) {
+            ret = realm_map_protected(realm, ipa, page, PAGE_SIZE, memcache);
+            if (ret) {
+                kvm_release_pfn_clean(pfn);
+                pr_err("[RME][add_granules] realm_map_protected failed: IPA=%pa ret=%d\n",
+                       &ipa, ret);
+                break;
+            }
+        }
+
+        kvm_release_pfn_clean(pfn);
+    }
+
+    srcu_read_unlock(&kvm->srcu, idx);
+    return ret;
+}

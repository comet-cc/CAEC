From c5dd510f793ab92c67afcf39eb7c4ccd1a640a76 Mon Sep 17 00:00:00 2001
From: SinaAb7 <sinaabdollahip@gmail.com>
Date: Fri, 1 May 2026 19:21:17 +0100
Subject: [PATCH 2/2] kvm/rme: add SMC latency instrumentation for
 DATA_CREATE_UNKNOWN and DATA_DESTROY

Wrap rmi_data_create_unknown() and rmi_data_destroy() in thin measurement
shims that capture both PMCCNTR_EL0 cycle counts (when pmu_enable.ko has
armed the cycle counter on all CPUs) and ktime_get_ns() wall-clock
nanoseconds around each SMC call.

Aggregate counters (total cycles, total ns, call count, skip count) are
kept in per-operation atomic64 structures. A debugfs file at
/sys/kernel/debug/rme_smc_stats exposes per-operation totals and
per-call averages; writing anything to the file resets all counters.

Usage:
  cat /sys/kernel/debug/rme_smc_stats          # read stats
  echo 0 | sudo tee /sys/kernel/debug/rme_smc_stats  # reset

Cycle counts require pmu_enable.ko to be loaded first; nanosecond
timings are always valid.
---
 arch/arm64/kvm/rme.c | 152 +++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 148 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/kvm/rme.c b/arch/arm64/kvm/rme.c
index 2bcd218834b6..cc9b508964a5 100644
--- a/arch/arm64/kvm/rme.c
+++ b/arch/arm64/kvm/rme.c
@@ -1,5 +1,10 @@
 #include <linux/kvm_host.h>
 #include <linux/hugetlb.h>
+#include <linux/atomic.h>
+#include <linux/debugfs.h>
+#include <linux/math64.h>
+#include <linux/seq_file.h>
+#include <linux/timekeeping.h>
 
 #include <asm/kvm_emulate.h>
 #include <asm/kvm_mmu.h>
@@ -8,6 +13,142 @@
 
 #include <asm/kvm_pgtable.h>
 
+/* SMC latency statistics for DATA_CREATE_UNKNOWN and DATA_DESTROY */
+struct rme_smc_stats {
+	atomic64_t cycles;	/* total PMCCNTR_EL0 cycles (needs pmu_enable.ko) */
+	atomic64_t ns;		/* total nanoseconds via ktime_get_ns() */
+	atomic64_t calls;	/* successful granule operations */
+	atomic64_t skips;	/* operations that returned an error */
+};
+
+static struct rme_smc_stats rme_stat_create_unk;
+static struct rme_smc_stats rme_stat_destroy;
+static struct dentry        *rme_stats_dentry;
+
+static __always_inline u64 rme_rdpmc(void)
+{
+	u64 val;
+
+	asm volatile("isb; mrs %0, pmccntr_el0; isb" : "=r"(val) :: "memory");
+	return val;
+}
+
+static void rme_stats_record(struct rme_smc_stats *s,
+			     u64 cy0, u64 cy1, u64 ns0, u64 ns1)
+{
+	atomic64_add(cy1 - cy0, &s->cycles);
+	atomic64_add(ns1 - ns0, &s->ns);
+	atomic64_inc(&s->calls);
+}
+
+static int rme_rmi_data_create_unknown(unsigned long rd,
+				       unsigned long data,
+				       unsigned long ipa)
+{
+	u64 cy0, cy1, ns0, ns1;
+	int ret;
+
+	cy0 = rme_rdpmc();
+	ns0 = ktime_get_ns();
+	ret = rmi_data_create_unknown(rd, data, ipa);
+	ns1 = ktime_get_ns();
+	cy1 = rme_rdpmc();
+
+	if (RMI_RETURN_STATUS(ret) == RMI_SUCCESS)
+		rme_stats_record(&rme_stat_create_unk, cy0, cy1, ns0, ns1);
+	else
+		atomic64_inc(&rme_stat_create_unk.skips);
+	return ret;
+}
+
+static int rme_rmi_data_destroy(unsigned long rd, unsigned long ipa,
+				unsigned long *data_out, unsigned long *top_out)
+{
+	u64 cy0, cy1, ns0, ns1;
+	int ret;
+
+	cy0 = rme_rdpmc();
+	ns0 = ktime_get_ns();
+	ret = rmi_data_destroy(rd, ipa, data_out, top_out);
+	ns1 = ktime_get_ns();
+	cy1 = rme_rdpmc();
+
+	if (RMI_RETURN_STATUS(ret) == RMI_SUCCESS)
+		rme_stats_record(&rme_stat_destroy, cy0, cy1, ns0, ns1);
+	else
+		atomic64_inc(&rme_stat_destroy.skips);
+	return ret;
+}
+
+static int rme_stats_show(struct seq_file *m, void *v)
+{
+	s64 calls_cu = atomic64_read(&rme_stat_create_unk.calls);
+	s64 calls_d  = atomic64_read(&rme_stat_destroy.calls);
+	s64 cy_cu    = atomic64_read(&rme_stat_create_unk.cycles);
+	s64 cy_d     = atomic64_read(&rme_stat_destroy.cycles);
+	s64 ns_cu    = atomic64_read(&rme_stat_create_unk.ns);
+	s64 ns_d     = atomic64_read(&rme_stat_destroy.ns);
+	s64 skips_cu = atomic64_read(&rme_stat_create_unk.skips);
+	s64 skips_d  = atomic64_read(&rme_stat_destroy.skips);
+
+	seq_puts(m, "# RMI SMC latency statistics\n");
+	seq_puts(m, "# cycles require pmu_enable.ko; ns is always valid\n\n");
+
+	seq_puts(m, "[DATA_CREATE_UNKNOWN]\n");
+	seq_printf(m, "  successful_calls : %lld\n", calls_cu);
+	seq_printf(m, "  skipped_calls    : %lld\n", skips_cu);
+	seq_printf(m, "  total_cycles     : %lld\n", cy_cu);
+	seq_printf(m, "  total_ns         : %lld\n", ns_cu);
+	if (calls_cu > 0) {
+		seq_printf(m, "  avg_cycles/call  : %lld\n",
+			   div64_s64(cy_cu, calls_cu));
+		seq_printf(m, "  avg_ns/call      : %lld\n",
+			   div64_s64(ns_cu, calls_cu));
+	}
+
+	seq_puts(m, "\n[DATA_DESTROY]\n");
+	seq_printf(m, "  successful_calls : %lld\n", calls_d);
+	seq_printf(m, "  skipped_calls    : %lld\n", skips_d);
+	seq_printf(m, "  total_cycles     : %lld\n", cy_d);
+	seq_printf(m, "  total_ns         : %lld\n", ns_d);
+	if (calls_d > 0) {
+		seq_printf(m, "  avg_cycles/call  : %lld\n",
+			   div64_s64(cy_d, calls_d));
+		seq_printf(m, "  avg_ns/call      : %lld\n",
+			   div64_s64(ns_d, calls_d));
+	}
+	return 0;
+}
+
+static int rme_stats_open(struct inode *inode, struct file *file)
+{
+	return single_open(file, rme_stats_show, NULL);
+}
+
+static ssize_t rme_stats_write(struct file *file, const char __user *buf,
+			       size_t count, loff_t *ppos)
+{
+	/* Any write resets all counters */
+	atomic64_set(&rme_stat_create_unk.cycles, 0);
+	atomic64_set(&rme_stat_create_unk.ns,     0);
+	atomic64_set(&rme_stat_create_unk.calls,  0);
+	atomic64_set(&rme_stat_create_unk.skips,  0);
+	atomic64_set(&rme_stat_destroy.cycles,    0);
+	atomic64_set(&rme_stat_destroy.ns,        0);
+	atomic64_set(&rme_stat_destroy.calls,     0);
+	atomic64_set(&rme_stat_destroy.skips,     0);
+	return count;
+}
+
+static const struct file_operations rme_stats_fops = {
+	.owner   = THIS_MODULE,
+	.open    = rme_stats_open,
+	.read    = seq_read,
+	.write   = rme_stats_write,
+	.llseek  = seq_lseek,
+	.release = single_release,
+};
+
 static unsigned long rmm_feat_reg0;
 /* forward decl: used by the cap handler below */
 int kvm_realm_prealloc_rtt_range(struct kvm *kvm, u64 ipa, u64 size, u32 target_level);
@@ -147,7 +288,7 @@ static int realm_destroy_protected(struct realm *realm,
 	int ret;
 
 loop:
-	ret = rmi_data_destroy(rd, ipa, &addr, next_addr);
+	ret = rme_rmi_data_destroy(rd, ipa, &addr, next_addr);
 	if (RMI_RETURN_STATUS(ret) == RMI_ERROR_RTT) {
 		if (*next_addr > ipa)
 			return 0; /* UNASSIGNED */
@@ -837,8 +978,8 @@ int realm_map_protected(struct realm *realm,
 			pr_info("Page already mapped at IPA 0x%lx\n", ipa);
 			return 0;
 		}
-		ret = rmi_data_create_unknown(rd, phys, ipa);
-		
+		ret = rme_rmi_data_create_unknown(rd, phys, ipa);
+
 		if (RMI_RETURN_STATUS(ret) == RMI_ERROR_RTT) {
 			/* Create missing RTTs and retry */
 			int level = RMI_RETURN_INDEX(ret);
@@ -850,7 +991,7 @@ int realm_map_protected(struct realm *realm,
 			if (ret)
 				goto err_undelegate;
 
-			ret = rmi_data_create_unknown(rd, phys, ipa);
+			ret = rme_rmi_data_create_unknown(rd, phys, ipa);
 		}
 	
 			
@@ -1771,6 +1912,9 @@ void kvm_init_rme(void)
 		return;
 
 	static_branch_enable(&kvm_rme_is_available);
+
+	rme_stats_dentry = debugfs_create_file("rme_smc_stats", 0644, NULL,
+					       NULL, &rme_stats_fops);
 }
 void kvm_realm_ensure_spare_page(struct kvm *kvm)
 {
